<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="egovframework.portal.video.mapper.VideoMapper">

    <resultMap id="videoResultMap" type="egovframework.portal.video.dto.VideoDTO">
        <id property="vdoOid" column="vdo_oid"/>
        <result property="vdoTtl" column="vdo_ttl"/>
        <result property="vdoExpln" column="vdo_expln"/>
        <result property="vdoUrl" column="vdo_url"/>
        <result property="thmbPath" column="thmb_path"/>
        <result property="inqCnt" column="inq_cnt"/>
        <result property="openYn" column="open_yn"/>
        <result property="useYn" column="use_yn"/>
        <result property="regId" column="reg_id"/>
        <result property="regDt" column="reg_dt"/>
        <result property="mdfcnId" column="mdfcn_id"/>
        <result property="mdfcnDt" column="mdfcn_dt"/>
    </resultMap>

    <!-- Video 게시판 게시글 목록 조회 with Filter -->
    <select id="selectVideoPostListWithFilter" resultMap="videoResultMap">
        SELECT
        vdo_oid,
        vdo_ttl,
        vdo_expln,
        vdo_url,
        thmb_path,
        inq_cnt,
        open_yn,
        use_yn,
        reg_id,
        reg_dt,
        mdfcn_id,
        mdfcn_dt
        FROM ${schema}.vdo
        <where>
            use_yn = 'Y'
            AND open_yn = 'Y'
            <if test="keyword != null and keyword != ''">
                AND
                (vdo_ttl LIKE CONCAT('%', #{keyword}, '%')
                OR vdo_expln LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY vdo_oid DESC
    </select>

    <!-- Video 게시판 게시글 조회 -->
    <select id="selectVideoById" resultMap="videoResultMap">
        SELECT
            vdo_oid,
            vdo_ttl,
            vdo_expln,
            vdo_url,
            thmb_path,
            inq_cnt,
            open_yn,
            use_yn,
            reg_id,
            reg_dt,
            mdfcn_id,
            mdfcn_dt
        FROM ${schema}.vdo
        WHERE vdo_oid = #{vdoOid}
    </select>

    <!-- video 게시판 이전 게시글 조회 -->
    <select id="selectPrevVideo" resultMap="videoResultMap">
        SELECT
            vdo_oid,
            vdo_ttl
        FROM ${schema}.vdo
        WHERE use_yn = 'Y'
          AND open_yn = 'Y'
          AND vdo_oid &lt; #{vdoOid}
        ORDER BY vdo_oid DESC
        LIMIT 1
    </select>

    <!-- video 게시판 다음 게시글 조회 -->
    <select id="selectNextVideo" resultMap="videoResultMap">
        SELECT
            vdo_oid,
            vdo_ttl
        FROM ${schema}.vdo
        WHERE use_yn = 'Y'
          AND open_yn = 'Y'
          AND vdo_oid &gt; #{vdoOid}
        ORDER BY vdo_oid ASC
        LIMIT 1
    </select>

    <!--video 게시판 조회수 증가-->
    <!--<update id="increaseVideoHitCount" parameterType="Long">
        UPDATE ${schema}.vdo
        SET inq_cnt = inq_cnt + 1
        WHERE vdo_oid = #{vdoOid}
    </update>-->
</mapper>