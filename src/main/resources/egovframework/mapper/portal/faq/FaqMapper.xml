<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="egovframework.portal.faq.mapper.FaqMapper">

    <resultMap id="faqResultMap" type="egovframework.portal.faq.dto.FaqDTO">
        <id property="faqDtlOid" column="faq_dtl_oid"/>
        <result property="faqCtgryOid" column="faq_ctgry_oid"/>
        <result property="qstnCn" column="qstn_cn"/>
        <result property="ansCn" column="ans_cn"/>
        <result property="sortSeq" column="sort_seq"/>
        <result property="openYn" column="open_yn"/>
        <result property="useYn" column="use_yn"/>
        <result property="inqCnt" column="inq_cnt"/>
        <result property="regId" column="reg_id"/>
        <result property="regDt" column="reg_dt"/>
        <result property="mdfcnId" column="mdfcn_id"/>
        <result property="mdfcnDt" column="mdfcn_dt"/>
    </resultMap>

    <resultMap id="faqCategoryResultMap" type="egovframework.portal.faq.dto.FaqCategoryDTO">
        <id property="faqCtgryOid" column="faq_ctgry_oid"/>
        <result property="ctgryNm" column="ctgry_nm"/>
        <result property="sortSeq" column="sort_seq"/>
        <result property="useYn" column="use_yn"/>
        <result property="regId" column="reg_id"/>
        <result property="regDt" column="reg_dt"/>
        <result property="mdfcnId" column="mdfcn_id"/>
        <result property="mdfcnDt" column="mdfcn_dt"/>
    </resultMap>

    <!-- Faq 게시판 카테고리 목록 조회 -->
    <select id="selectFaqCategoryList" resultMap="faqCategoryResultMap">
        SELECT
            faq_ctgry_oid,
            ctgry_nm,
            sort_seq,
            use_yn,
            reg_id,
            reg_dt,
            mdfcn_id,
            mdfcn_dt
        FROM
            ${schema}.faq_ctgry
        WHERE
            use_yn = 'Y'
        AND open_yn = 'Y'
        ORDER BY
            sort_seq ASC, faq_ctgry_oid DESC
    </select>

    <!-- Faq 게시판 게시글 목록 조회 with Filter -->
    <select id="selectFaqPostListWithFilter" resultMap="faqResultMap">
        SELECT
            tfd.faq_dtl_oid,
            tfd.faq_ctgry_oid,
            tfd.qstn_cn,
            tfd.ans_cn,
            tfd.sort_seq,
            tfd.open_yn,
            tfd.use_yn,
            tfd.inq_cnt,
            tfd.reg_id,
            tfd.reg_dt,
            tfd.mdfcn_id,
            tfd.mdfcn_dt
        FROM
            ${schema}.faq_dtl tfd
        LEFT JOIN ${schema}.faq_ctgry tfc ON
        	tfc.faq_ctgry_oid = tfd.faq_ctgry_oid
        	AND tfc.use_yn = 'Y'
        <where>
            tfd.use_yn = 'Y'
            AND tfd.open_yn = 'Y'
            <if test="keyword != null and keyword != ''">
                AND (
                    tfd.qstn_cn LIKE CONCAT('%', #{keyword}, '%')
                    OR tfd.ans_cn LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="faqCtgryOid != null and faqCtgryOid != ''">
                AND tfd.faq_ctgry_oid = #{faqCtgryOid}
            </if>
            <if test="ctgry != null and ctgry != ''">
                AND ctgry_cd = #{ctgry}
            </if>            
        </where>
        ORDER BY sort_seq ASC, faq_dtl_oid DESC
    </select>
</mapper>