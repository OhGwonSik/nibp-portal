<?xml version="1.0" encoding="UTF-8"?>
<!-- local : 로컬-정책원 DB -->
<Configuration status="INFO" monitorInterval="30">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="LOG_PATH">/app/logs</Property>
        <Property name="LOG_FILE">${LOG_PATH}/dev.log</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%highlight{%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n}" />
        </Console>

        <RollingFile name="RollingFile"
                     fileName="${LOG_FILE}"
                     filePattern="${LOG_PATH}/dev-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout>
                <Pattern>${LOG_PATTERN}</Pattern>
            </PatternLayout>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Development specific loggers -->
        <Logger name="org.springframework" level="INFO" />
        <Logger name="org.hibernate" level="INFO" />
        <Logger name="egovframework" level="DEBUG" />
        <Logger name="org.egovframe" level="DEBUG" />
        <Logger name="java.sql" level="DEBUG" />
        <Logger name="jdbc.sqltiming" level="DEBUG" />
        <Logger name="org.springframework.transaction" level="DEBUG" />
        <logger name="org.mybatis.spring" level="TRACE"/>
        <Logger name="p6spy" level="INFO" />
        
        <Root level="INFO">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
        </Root>
    </Loggers>
</Configuration>
