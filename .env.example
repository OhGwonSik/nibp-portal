#############################################
# nibp-portal 환경변수 (.env.example)
# 실제 운영 시 .env 파일로 복사 후 값을 채워 사용
# Docker Compose / Spring Boot 환경변수 바인딩 기준
#############################################

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:p6spy:mariadb://<DB_HOST>:3306/konibp_db?characterEncoding=UTF-8&useUnicode=true
SPRING_DATASOURCE_USERNAME=nibp-portal
SPRING_DATASOURCE_PASSWORD=

# --- Mail ---
SPRING_MAIL_HOST=
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_TRUST=

# --- Base URL ---
COMMON_BASE_URL=https://nibp.kr

# --- JWT ---
JWT_SECRET=

# --- AES ---
AES_SECRET_KEY=
AES_SECRET_IV=

# --- NICE 본인인증 ---
NICE_CP_SITECODE=
NICE_CP_SITEPASSWORD=

# --- Redis ---
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=

# --- Mailing ---
MAILING_AUTH_CHARACTERS=
MAILING_NOTIFICATION_RECEIVERS=
